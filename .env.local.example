ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ─── Resend (transactional email) ─────────────────────────────────────────────
# Get from: resend.com — add aryo.london as sending domain first
RESEND_API_KEY=re_your_resend_api_key

# ─── getAddress.io (UK postcode address lookup) ───────────────────────────────
# Get from: getaddress.io — free tier: 20 lookups/day
# Without this, only district-level data is returned via postcodes.io
# NEXT_PUBLIC_GETADDRESS_API_KEY=your-key-here

# ─── WalletConnect (crypto payments) ─────────────────────────────────────────
# Get free project ID from: cloud.walletconnect.com → Create Project
# Without this, the Crypto tab is hidden on checkout
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# Your Ethereum wallet address (payments sent here)
# NEXT_PUBLIC_ARYO_WALLET_ADDRESS=0xYourWalletAddressHere

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aryo.london
